{
  "name": "${localWorkspaceFolderBasename}",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "runArgs": ["--device", "nvidia.com/gpu=all"],
  "mounts": [
    // SSH keys and git identity from host
    "source=${localEnv:HOME}/.ssh,target=/root/.ssh,type=bind,readonly",
    "source=${localEnv:HOME}/.gitconfig,target=/root/.gitconfig,type=bind,consistency=cached",
    // Claude Code and GitHub Copilot auth from host
    "source=${localEnv:HOME}/.claude,target=/root/.claude,type=bind,consistency=cached",
    "source=${localEnv:HOME}/.copilot,target=/root/.copilot,type=bind,consistency=cached",
    // Persistent volumes so history and zoxide jump db survive rebuilds
    "source=${localWorkspaceFolderBasename}_zsh_history,target=/root/.local/share/zsh,type=volume",
    "source=${localWorkspaceFolderBasename}_zoxide,target=/root/.local/share/zoxide,type=volume"
  ],
  "postCreateCommand": "uv venv --allow-existing .venv && uv pip install --python .venv/bin/python -r requirements.txt",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "tamasfe.even-better-toml",
        "redhat.vscode-yaml",
        "eamodio.gitlens",
        "usernamehw.errorlens",
        "esbenp.prettier-vscode",
        "anthropic.claude-code",
        "ms-toolsai.jupyter"
      ],
      "settings": {
        "terminal.integrated.profiles.linux": {
          "zsh": { "path": "/bin/zsh" }
        },
        "terminal.integrated.defaultProfile.linux": "zsh",
        "editor.formatOnSave": true,
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff"
        }
      }
    }
  }
}
